# Waypointer Environment Variables
# Copy this file to .env.local and fill in real values.
# See CLAUDE.md Rule 2 for full documentation.

# ─── Supabase (required) ─────────────────────────────────────────────
# Client-safe (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Provider (required) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Voice Interviews (required) ─────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key

# ─── Job Data (required) ─────────────────────────────────────────────
JOB_DATA_API_KEY=your-jsearch-api-key

# ─── Email (required) ────────────────────────────────────────────────
EMAIL_PROVIDER_API_KEY=your-email-provider-key

# ─── Application URL (optional — auto-detected on Vercel) ────────────
# Set explicitly for custom domains. Falls back to VERCEL_URL.
# NEXT_PUBLIC_APP_URL=https://waypointer.com

# ─── Cron Security (required for production) ─────────────────────────
# Vercel Cron uses this to authenticate scheduled job requests.
CRON_SECRET=your-cron-secret
